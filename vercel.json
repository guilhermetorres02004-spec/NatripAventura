{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "favicon.ico",
          "css/**",
          "js/**",
          "img/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "\/(.*)", "dest": "server.js" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}